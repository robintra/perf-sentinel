{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/robintra/perf-sentinel/main/docs/schemas/perf-sentinel-report-v1.json",
  "title": "perf-sentinel periodic disclosure report",
  "description": "Aggregated, hash-verifiable disclosure of perf-sentinel detections over a calendar period (typically a quarter). Intended for public transparency. Distinct from the per-batch Report tree.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "report_metadata",
    "organisation",
    "period",
    "scope_manifest",
    "methodology",
    "aggregate",
    "applications",
    "integrity",
    "notes"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "perf-sentinel-report/v1.0",
        "perf-sentinel-report/v1.1",
        "perf-sentinel-report/v1.2"
      ]
    },
    "report_metadata": { "$ref": "#/$defs/ReportMetadata" },
    "organisation": { "$ref": "#/$defs/Organisation" },
    "period": { "$ref": "#/$defs/Period" },
    "scope_manifest": { "$ref": "#/$defs/ScopeManifest" },
    "methodology": { "$ref": "#/$defs/Methodology" },
    "aggregate": { "$ref": "#/$defs/Aggregate" },
    "applications": {
      "type": "array",
      "description": "Per-application breakdown. Either all entries are G1 (with anti_patterns detail, intended for internal disclosures) or all entries are G2 (without anti_patterns detail, intended for public disclosures). The validator enforces homogeneity.",
      "items": {
        "oneOf": [
          { "$ref": "#/$defs/ApplicationG1" },
          { "$ref": "#/$defs/ApplicationG2" }
        ]
      }
    },
    "integrity": { "$ref": "#/$defs/Integrity" },
    "notes": { "$ref": "#/$defs/Notes" }
  },
  "$defs": {
    "ReportIntent": {
      "type": "string",
      "enum": ["internal", "official", "audited"]
    },
    "Confidentiality": {
      "type": "string",
      "enum": ["internal", "public"]
    },
    "IntegrityLevel": {
      "type": "string",
      "enum": ["none", "hash-only", "signed", "signed-with-attestation", "audited"]
    },
    "PeriodType": {
      "type": "string",
      "enum": ["calendar-quarter", "calendar-month", "calendar-year", "custom"]
    },
    "Conformance": {
      "type": "string",
      "enum": ["core-required", "extended", "partial"]
    },
    "Iso8601DateTime": {
      "type": "string",
      "format": "date-time",
      "description": "RFC 3339 / ISO 8601 instant, UTC."
    },
    "Iso8601Date": {
      "type": "string",
      "format": "date",
      "description": "ISO 8601 calendar date, YYYY-MM-DD."
    },
    "UuidV4": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
    },
    "Sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "PatternName": {
      "type": "string",
      "enum": [
        "n_plus_one_sql",
        "n_plus_one_http",
        "redundant_sql",
        "redundant_http",
        "slow_sql",
        "slow_http",
        "excessive_fanout",
        "chatty_service",
        "pool_saturation",
        "serialized_calls"
      ]
    },
    "CarbonIntensitySource": {
      "type": "string",
      "enum": ["electricity_maps", "static_tables", "mixed"]
    },
    "ReportMetadata": {
      "type": "object",
      "required": [
        "intent",
        "confidentiality_level",
        "integrity_level",
        "generated_at",
        "generated_by",
        "perf_sentinel_version",
        "report_uuid"
      ],
      "properties": {
        "intent": { "$ref": "#/$defs/ReportIntent" },
        "confidentiality_level": { "$ref": "#/$defs/Confidentiality" },
        "integrity_level": { "$ref": "#/$defs/IntegrityLevel" },
        "generated_at": { "$ref": "#/$defs/Iso8601DateTime" },
        "generated_by": {
          "type": "string",
          "enum": ["daemon", "cli-batch", "ci"]
        },
        "perf_sentinel_version": { "type": "string", "minLength": 1 },
        "report_uuid": { "$ref": "#/$defs/UuidV4" },
        "binary_version": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._+-]+$",
          "maxLength": 64,
          "description": "Binary that wrote this disclosure file. Mirrors the per-window Report.binary_version; same convention so disclosure files and source archives are indexable on a single key. May be absent for disclosure files produced before this field shipped (0.7.0+)."
        }
      }
    },
    "Organisation": {
      "type": "object",
      "required": ["name", "country", "identifiers"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "country": {
          "type": "string",
          "pattern": "^[A-Z]{2}$",
          "description": "ISO 3166-1 alpha-2 country code, upper case."
        },
        "identifiers": { "$ref": "#/$defs/OrgIdentifiers" },
        "sector": {
          "type": "string",
          "description": "NACE rev2 code, e.g. 62.01."
        }
      }
    },
    "OrgIdentifiers": {
      "type": "object",
      "properties": {
        "siren": { "type": "string" },
        "vat": { "type": "string" },
        "lei": { "type": "string" },
        "opencorporates_url": { "type": "string", "format": "uri" },
        "domain": { "type": "string" }
      }
    },
    "Period": {
      "type": "object",
      "required": ["from_date", "to_date", "period_type", "days_covered"],
      "properties": {
        "from_date": { "$ref": "#/$defs/Iso8601Date" },
        "to_date": { "$ref": "#/$defs/Iso8601Date" },
        "period_type": { "$ref": "#/$defs/PeriodType" },
        "days_covered": { "type": "integer", "minimum": 0 }
      }
    },
    "ScopeManifest": {
      "type": "object",
      "required": [
        "total_applications_declared",
        "applications_measured",
        "requests_measured"
      ],
      "properties": {
        "total_applications_declared": { "type": "integer", "minimum": 0 },
        "applications_measured": { "type": "integer", "minimum": 0 },
        "applications_excluded": {
          "type": "array",
          "items": { "$ref": "#/$defs/ExcludedApp" }
        },
        "environments_measured": {
          "type": "array",
          "items": { "type": "string" }
        },
        "environments_excluded": {
          "type": "array",
          "items": { "$ref": "#/$defs/ExcludedEnv" }
        },
        "total_requests_in_period": { "type": "integer", "minimum": 0 },
        "requests_measured": { "type": "integer", "minimum": 0 },
        "coverage_percentage": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "requests_measured / total_requests_in_period * 100 when the latter is set. Machine-derived; see coverage_basis."
        },
        "coverage_basis": {
          "$ref": "#/$defs/CoverageBasis",
          "description": "Since v1.2. In-band provenance marker: which scope fields are operator-asserted (unaudited) versus machine-derived from the archives. Constant per schema version."
        }
      }
    },
    "CoverageBasis": {
      "type": "object",
      "description": "Provenance split for the ScopeManifest. The operator_declared fields rest on unaudited operator assertion (the binary cannot verify the portfolio size they describe); the machine_derived fields are computed by the aggregator.",
      "required": ["operator_declared", "machine_derived"],
      "properties": {
        "operator_declared": {
          "type": "array",
          "items": { "type": "string" }
        },
        "machine_derived": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "ExcludedApp": {
      "type": "object",
      "required": ["service_name", "reason"],
      "properties": {
        "service_name": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 }
      }
    },
    "ExcludedEnv": {
      "type": "object",
      "required": ["name", "reason"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 }
      }
    },
    "Methodology": {
      "type": "object",
      "required": [
        "sci_specification",
        "perf_sentinel_version",
        "enabled_patterns",
        "core_patterns_required",
        "conformance",
        "calibration_inputs"
      ],
      "properties": {
        "sci_specification": { "type": "string", "minLength": 1 },
        "perf_sentinel_version": { "type": "string", "minLength": 1 },
        "enabled_patterns": {
          "type": "array",
          "items": { "$ref": "#/$defs/PatternName" }
        },
        "disabled_patterns": {
          "type": "array",
          "items": { "$ref": "#/$defs/DisabledPattern" }
        },
        "core_patterns_required": {
          "type": "array",
          "items": { "$ref": "#/$defs/PatternName" }
        },
        "conformance": { "$ref": "#/$defs/Conformance" },
        "calibration_inputs": { "$ref": "#/$defs/CalibrationInputs" }
      }
    },
    "DisabledPattern": {
      "type": "object",
      "required": ["name", "reason"],
      "properties": {
        "name": { "$ref": "#/$defs/PatternName" },
        "reason": { "type": "string", "minLength": 1 }
      }
    },
    "CalibrationInputs": {
      "type": "object",
      "required": [
        "carbon_intensity_source",
        "specpower_table_version",
        "scaphandre_used"
      ],
      "properties": {
        "cloud_regions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "carbon_intensity_source": { "$ref": "#/$defs/CarbonIntensitySource" },
        "specpower_table_version": { "type": "string", "minLength": 1, "maxLength": 64 },
        "binary_specpower_vintage": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "description": "Vintage string of the SPECpower / CCF coefficient table embedded in the running binary. Independent of the operator-declared specpower_table_version above. Consumers may compare both strings to detect drift between operator disclosure and embedded data."
        },
        "scaphandre_used": { "type": "boolean" },
        "energy_source_models": {
          "type": "array",
          "description": "Distinct energy_model strings observed across the archived windows feeding this disclosure. Sorted set in the wire form. Empty when every window predates per-service carbon attribution.",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64,
            "pattern": "^[a-z0-9_+-]+$"
          },
          "uniqueItems": true,
          "maxItems": 64
        },
        "calibration_applied": {
          "type": "boolean",
          "default": false,
          "description": "True if at least one scoring window in the period had operator-supplied per-service calibration coefficients applied to the proxy energy (i.e. emitted an energy_model with the +cal suffix). Period-wide binary flag, distinct from energy_source_models which describes which source produced the numbers (0.7.0+)."
        }
      }
    },
    "WasteTier": {
      "type": "object",
      "required": [
        "n_plus_one_threshold",
        "energy_kwh",
        "carbon_kgco2eq",
        "waste_ratio",
        "efficiency_score"
      ],
      "properties": {
        "n_plus_one_threshold": { "type": "integer", "minimum": 0 },
        "energy_kwh": { "type": "number", "minimum": 0 },
        "carbon_kgco2eq": { "type": "number", "minimum": 0 },
        "waste_ratio": { "type": "number", "minimum": 0, "maximum": 1 },
        "efficiency_score": { "type": "number", "minimum": 0, "maximum": 100 }
      }
    },
    "Aggregate": {
      "type": "object",
      "required": [
        "total_requests",
        "total_energy_kwh",
        "total_carbon_kgco2eq",
        "aggregate_efficiency_score",
        "aggregate_waste_ratio",
        "anti_patterns_detected_count",
        "estimated_optimization_potential_kgco2eq"
      ],
      "properties": {
        "total_requests": { "type": "integer", "minimum": 0 },
        "total_energy_kwh": { "type": "number", "minimum": 0 },
        "total_carbon_kgco2eq": { "type": "number", "minimum": 0 },
        "aggregate_efficiency_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "aggregate_waste_ratio": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "anti_patterns_detected_count": { "type": "integer", "minimum": 0 },
        "estimated_optimization_potential_kgco2eq": {
          "type": "number",
          "minimum": 0
        },
        "canonical_waste": {
          "$ref": "#/$defs/WasteTier",
          "description": "Avoidable energy/carbon at the binary-pinned canonical N+1 threshold (non-manipulable by operator config). The flat aggregate_* and estimated_optimization_potential_kgco2eq fields alias this tier. v1.1+."
        },
        "operational_waste": {
          "$ref": "#/$defs/WasteTier",
          "description": "Avoidable energy/carbon at the operator's configured N+1 threshold, recorded with that threshold so the gap to canonical_waste is visible. v1.1+."
        },
        "period_coverage": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 1.0,
          "description": "Fraction of the period's scoring windows that used runtime-calibrated energy attribution. 1.0 means every window provided runtime energy, 0.0 means every window fell back to the proxy. Absence is treated as 1.0 for backward compatibility with archives produced before this field shipped."
        },
        "binary_versions": {
          "type": "array",
          "uniqueItems": true,
          "maxItems": 256,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64,
            "pattern": "^[A-Za-z0-9._+-]+$"
          },
          "description": "Set of distinct perf-sentinel binary versions observed across the period's windows. Empty if every window predates the field."
        },
        "runtime_windows_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of scoring windows that used runtime-calibrated attribution. Combined with fallback_windows_count, gives the absolute volume behind period_coverage."
        },
        "fallback_windows_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of scoring windows that fell back to the proxy attribution path."
        },
        "per_service_energy_models": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "uniqueItems": true,
            "maxItems": 64,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 64,
              "pattern": "^[a-z0-9_+-]+$"
            }
          },
          "description": "Per-service set of distinct energy models observed across the period's windows. The +cal suffix is stripped before insertion; see methodology.calibration_inputs.calibration_applied for the period-wide flag."
        },
        "per_service_measured_ratio": {
          "type": "object",
          "additionalProperties": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "description": "Per-service mean of the per-window measured-ratio across the period. 1.0 means every span had measured energy across every window; 0.0 means the service fell back to proxy entirely."
        },
        "temporal_coverage": {
          "$ref": "#/$defs/TemporalCoverage",
          "description": "Since v1.2. Continuity signal: how many declared calendar days carried archived windows. Absent (or all-zero) on pre-v1.2 reports."
        }
      }
    },
    "TemporalCoverage": {
      "type": "object",
      "description": "Since v1.2. Measures days with OBSERVED TRAFFIC, not daemon uptime: archiving is traffic-gated, so a window with no traffic writes nothing and legitimately quiet days (nights, weekends, low-traffic services) lower this figure. Published for transparency and surfaced as a warning when low, never a hard official gate.",
      "required": [
        "temporal_coverage",
        "observed_days",
        "days_in_period",
        "largest_gap_days"
      ],
      "properties": {
        "temporal_coverage": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "observed_days / days_in_period."
        },
        "observed_days": {
          "type": "integer",
          "minimum": 0,
          "description": "Distinct UTC calendar days in the period that carry at least one archived window."
        },
        "days_in_period": {
          "type": "integer",
          "minimum": 0,
          "description": "The period's declared days_covered, mirrored for self-containment."
        },
        "largest_gap_days": {
          "type": "integer",
          "minimum": 0,
          "description": "Longest run of consecutive in-period days with zero windows."
        }
      }
    },
    "ApplicationG1": {
      "type": "object",
      "required": [
        "service_name",
        "endpoints_observed",
        "total_requests",
        "energy_kwh",
        "carbon_kgco2eq",
        "efficiency_score",
        "anti_patterns"
      ],
      "properties": {
        "service_name": { "type": "string", "minLength": 1 },
        "display_name": { "type": "string" },
        "service_version": { "type": "string" },
        "endpoints_observed": { "type": "integer", "minimum": 0 },
        "total_requests": { "type": "integer", "minimum": 0 },
        "energy_kwh": { "type": "number", "minimum": 0 },
        "carbon_kgco2eq": { "type": "number", "minimum": 0 },
        "efficiency_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "anti_patterns": {
          "type": "array",
          "items": { "$ref": "#/$defs/AntiPatternDetail" }
        }
      },
      "not": { "required": ["anti_patterns_detected_count"] }
    },
    "ApplicationG2": {
      "type": "object",
      "required": [
        "service_name",
        "endpoints_observed",
        "total_requests",
        "energy_kwh",
        "carbon_kgco2eq",
        "efficiency_score",
        "anti_patterns_detected_count"
      ],
      "properties": {
        "service_name": { "type": "string", "minLength": 1 },
        "display_name": { "type": "string" },
        "service_version": { "type": "string" },
        "endpoints_observed": { "type": "integer", "minimum": 0 },
        "total_requests": { "type": "integer", "minimum": 0 },
        "energy_kwh": { "type": "number", "minimum": 0 },
        "carbon_kgco2eq": { "type": "number", "minimum": 0 },
        "efficiency_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "anti_patterns_detected_count": { "type": "integer", "minimum": 0 }
      },
      "not": { "required": ["anti_patterns"] }
    },
    "AntiPatternDetail": {
      "type": "object",
      "required": [
        "type",
        "occurrences",
        "estimated_waste_kwh",
        "estimated_waste_kgco2eq",
        "first_seen",
        "last_seen"
      ],
      "properties": {
        "type": { "$ref": "#/$defs/PatternName" },
        "occurrences": { "type": "integer", "minimum": 0 },
        "estimated_waste_kwh": { "type": "number", "minimum": 0 },
        "estimated_waste_kgco2eq": { "type": "number", "minimum": 0 },
        "first_seen": { "$ref": "#/$defs/Iso8601DateTime" },
        "last_seen": { "$ref": "#/$defs/Iso8601DateTime" }
      }
    },
    "Integrity": {
      "type": "object",
      "required": ["content_hash"],
      "properties": {
        "content_hash": {
          "oneOf": [
            { "$ref": "#/$defs/Sha256" },
            { "type": "string", "maxLength": 0 }
          ],
          "description": "SHA-256 over the canonical JSON form of the report with this field blanked to an empty string. Consumers verify by setting their own copy of content_hash to \"\" and recomputing."
        },
        "binary_hash": { "$ref": "#/$defs/Sha256" },
        "binary_verification_url": { "type": "string", "format": "uri" },
        "trace_integrity_chain": {
          "type": ["null", "object"],
          "description": "Reserved. Always null in schema v1.0."
        },
        "signature": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/SignatureMetadata" }
          ],
          "description": "Sigstore cosign in-toto signature locator. Null when the report is hash-only. Typed object when the report has been signed (0.7.0+)."
        },
        "binary_attestation": {
          "$ref": "#/$defs/BinaryAttestationMetadata",
          "description": "SLSA build provenance attestation for the perf-sentinel binary that produced this report. Present when the binary comes from a recognized SLSA L2+ builder (0.7.0+)."
        },
        "cross_period_log": {
          "$ref": "#/$defs/CrossPeriodLogRef",
          "description": "Reserved (v1.2). Locator for an external append-only / Rekor-style log that chains successive periodic reports, enabling inter-period continuity verification (detecting an operator who silently stopped publishing). Always absent in v1.2; populated only under a future intent=audited."
        }
      }
    },
    "CrossPeriodLogRef": {
      "type": "object",
      "description": "Reserved (v1.2) locator for an inter-period transparency log. The per-report integrity guarantees bind a single published report; a chained append-only log of successive content_hash values closes the gap for an operator who stops disclosing. No runtime support yet.",
      "required": ["format", "log_url"],
      "properties": {
        "format": { "type": "string" },
        "log_url": { "type": "string", "format": "uri" },
        "previous_report_hash": { "$ref": "#/$defs/Sha256" }
      }
    },
    "SignatureMetadata": {
      "type": "object",
      "required": [
        "format",
        "bundle_url",
        "signer_identity",
        "signer_issuer",
        "rekor_url",
        "rekor_log_index",
        "signed_at"
      ],
      "properties": {
        "format": {
          "type": "string",
          "enum": ["sigstore-cosign-intoto-v1"]
        },
        "bundle_url": { "type": "string", "format": "uri" },
        "signer_identity": { "type": "string", "minLength": 1 },
        "signer_issuer": { "type": "string", "format": "uri" },
        "rekor_url": { "type": "string", "format": "uri" },
        "rekor_log_index": { "type": "integer", "minimum": 0 },
        "signed_at": { "$ref": "#/$defs/Iso8601DateTime" }
      }
    },
    "BinaryAttestationMetadata": {
      "type": "object",
      "required": [
        "format",
        "attestation_url",
        "builder_id",
        "git_tag",
        "git_commit",
        "slsa_level"
      ],
      "properties": {
        "format": {
          "type": "string",
          "enum": ["slsa-provenance-v1"]
        },
        "attestation_url": { "type": "string", "format": "uri" },
        "builder_id": { "type": "string", "format": "uri" },
        "git_tag": {
          "type": "string",
          "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+([+-][A-Za-z0-9._-]+)?$"
        },
        "git_commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{7,40}$"
        },
        "slsa_level": {
          "type": "string",
          "enum": ["L2", "L3"]
        }
      }
    },
    "Notes": {
      "type": "object",
      "properties": {
        "disclaimers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "reference_urls": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    }
  }
}
