---
title: Detection orchestration
---
flowchart TD
    traces["Vec&lt;Trace&gt;"]

    subgraph pertrace["Per-trace detection"]
        direction TB
        npo["N+1 detection<br/><i>same template, different params<br/>within window_ms, &ge; threshold</i>"]
        red["Redundant detection<br/><i>same template AND same params<br/>&ge; 2 occurrences</i>"]
        slow["Slow detection<br/><i>duration &gt; threshold_ms<br/>&ge; min_occurrences</i>"]
        fan["Fanout detection<br/><i>children per parent &gt; max_fanout<br/>requires parent_span_id</i>"]
        chatty["Chatty service<br/><i>HTTP outbound calls &ge; min_calls<br/>per trace per service</i>"]
        pool["Pool saturation<br/><i>concurrent SQL spans &ge; threshold<br/>overlapping durations</i>"]
        serial["Serialized calls<br/><i>sequential independent siblings<br/>&ge; min_sequential</i>"]
        npo --> red --> slow --> fan --> chatty --> pool --> serial
    end

    cross["Cross-trace slow percentiles<br/><i>p50 / p95 / p99 per template<br/>&ge; 2 distinct traces</i>"]

    sort["sort_findings()<br/><i>deterministic output order</i>"]

    findings["Vec&lt;Finding&gt;"]

    traces --> pertrace
    traces --> cross
    pertrace --> sort
    cross --> sort
    sort --> findings

    style pertrace fill:#3b2d4a,stroke:#a78bfa
    style cross fill:#4a3b2d,stroke:#fbbf24
