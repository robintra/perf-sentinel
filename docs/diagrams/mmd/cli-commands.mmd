---
title: CLI commands overview
---
flowchart LR
    cli["perf-sentinel"]

    analyze["analyze<br/><i>--input file<br/>--ci --format json|sarif</i>"]
    explain["explain<br/><i>--trace-id ID<br/>--format text|json</i>"]
    inspect["inspect ⚙ tui<br/><i>--input file<br/>TUI mode</i>"]
    watch["watch ⚙ daemon<br/><i>daemon mode<br/>--config path</i>"]
    demo["demo<br/><i>embedded dataset</i>"]
    bench["bench<br/><i>--input file<br/>--iterations N</i>"]
    pgstat["pg-stat<br/><i>--input csv|json<br/>--prometheus URL<br/>--top-n N --traces file</i>"]
    tempo["tempo ⚙ tempo<br/><i>--endpoint URL<br/>--service name | --trace-id ID<br/>--lookback 1h</i>"]
    jaeger_query["jaeger-query ⚙ jaeger-query<br/><i>Jaeger or Victoria Traces<br/>--endpoint URL<br/>--service name | --trace-id ID<br/>--lookback 1h --max-traces N</i>"]
    calibrate["calibrate<br/><i>--traces file<br/>--measured-energy csv<br/>--output toml</i>"]
    query["query<br/><i>--daemon URL<br/>(subcommand)</i>"]
    ack["ack ⚙ daemon<br/><i>--daemon URL<br/>(subcommand: create|revoke|list)<br/>auth: env / --api-key-file / TTY prompt</i>"]
    report["report<br/><i>--input file|-<br/>--output report.html<br/>--pg-stat file | --pg-stat-prometheus URL<br/>--before baseline.json<br/>--max-traces-embedded N</i>"]
    diff["diff<br/><i>--before file --after file<br/>--format text|json|sarif</i>"]
    disclose["disclose<br/><i>--intent internal|official|audited<br/>--confidentiality internal|public<br/>--period-type calendar-*|custom<br/>--from --to YYYY-MM-DD<br/>--input ndjson archive(s)<br/>--org-config toml<br/>--emit-attestation (optional)</i>"]
    verify_hash["verify-hash<br/><i>--report file | --url URL<br/>--attestation in-toto v1<br/>--bundle cosign<br/>--expected-identity --expected-issuer<br/>--format text|json</i>"]
    hash_bake["hash-bake<br/><i>--report file --output file<br/>--allow-signed<br/>recompute canonical content_hash</i>"]

    analyze_pipeline["Pipeline<br/><i>normalize &rarr; correlate<br/>&rarr; detect &rarr; score</i>"]
    tempo_pipeline["Tempo fetch<br/>&rarr; pipeline"]
    jaeger_query_pipeline["Jaeger query fetch<br/>&rarr; pipeline"]
    inspect_pipeline["Pipeline + TUI<br/><i>ratatui 4-panel<br/>traces / findings / detail / correlations</i>"]
    demo_pipeline["Pipeline"]
    bench_pipeline["Pipeline<br/><i>throughput measurement</i>"]
    report_pipeline["Pipeline + HTML sink<br/><i>embed findings-only traces<br/>inline CSS / JS template</i>"]
    diff_engine["diff::diff_runs()<br/><i>identity match new /<br/>resolved / severity /<br/>endpoint deltas</i>"]
    tree["build_tree()<br/><i>span tree + findings</i>"]
    daemon["daemon::run()<br/><i>OTLP + streaming</i>"]
    ranking["rank_entries()<br/><i>top-N hotspots</i>"]
    cal_engine["calibrate()<br/><i>correlate ops + energy</i>"]
    disclose_engine["periodic::aggregate()<br/><i>filter window NDJSON<br/>+ official-intent validator<br/>+ canonical content_hash<br/>+ optional in-toto attestation</i>"]
    verify_engine["verify_hash::verify()<br/><i>recompute content_hash<br/>+ cosign verify-blob<br/>+ gh attestation verify</i>"]
    hashbake_engine["hash_bake::bake()<br/><i>recompute canonical hash<br/>atomic temp+rename</i>"]

    subgraph pgstat_sources["pg-stat data sources"]
        pg_file["CSV / JSON file<br/><i>--input path</i>"]
        pg_prom["Prometheus API<br/><i>--prometheus URL<br/>pg_stat_statements_*</i>"]
    end

    subgraph query_actions["query sub-actions"]
        q_findings["findings<br/><i>--service --type<br/>--severity --limit<br/>--format text|json</i>"]
        q_explain["explain<br/><i>--trace-id ID<br/>--format text|json</i>"]
        q_inspect["inspect ⚙ tui<br/><i>live TUI from daemon</i>"]
        q_correlations["correlations<br/><i>--format text|json</i>"]
        q_status["status<br/><i>--format text|json</i>"]
    end

    subgraph ack_actions["ack sub-actions"]
        a_create["create<br/><i>--signature --reason<br/>--expires --by<br/>POST /api/findings/{sig}/ack</i>"]
        a_revoke["revoke<br/><i>--signature<br/>DELETE /api/findings/{sig}/ack</i>"]
        a_list["list<br/><i>--output text|json<br/>GET /api/acks</i>"]
    end

    daemon_api["Daemon HTTP API<br/><i>:4318 /api/*</i>"]

    report_text["Colored<br/>terminal"]
    report_json["JSON<br/>report"]
    report_sarif["SARIF<br/>v2.1.0"]
    report_ndjson["NDJSON<br/>stdout"]
    report_metrics["Prometheus<br/>/metrics"]
    report_toml["Calibration<br/>TOML"]
    report_bench["JSON<br/>perf metrics"]
    report_html["HTML<br/>dashboard<br/><i>single file, offline</i>"]
    report_disclose["Disclosure<br/>JSON v1.0<br/><i>perf-sentinel-report.json<br/>+ optional in-toto attestation</i>"]
    report_verify["Verification<br/>result<br/><i>text or JSON</i>"]
    report_baked["Report<br/>with baked<br/>content_hash"]

