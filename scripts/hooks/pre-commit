#!/usr/bin/env bash
#
# perf-sentinel pre-commit hook: scan staged changes for secrets.
#
# Installed by `scripts/install-hooks.sh`. Skips itself gracefully if
# `gitleaks` is not on PATH so a fresh checkout does not fail
# `git commit` with a confusing error before the contributor has
# installed the tool. Surfaces a one-line install hint on first miss.
#
# Bypass: `git commit --no-verify` (use sparingly).

set -euo pipefail

if ! command -v gitleaks > /dev/null 2>&1; then
  echo "warning: gitleaks not on PATH; skipping pre-commit secret scan."
  echo "         install with 'brew install gitleaks' or see https://github.com/gitleaks/gitleaks"
  exit 0
fi

# `gitleaks git` was added in 8.16 and replaced the legacy
# `gitleaks protect --staged`. Probe the subcommand instead of parsing
# the version string so the check stays robust across `vX.Y.Z` and
# `X.Y.Z` formats.
if ! gitleaks git --help > /dev/null 2>&1; then
  installed_version="$(gitleaks version 2>/dev/null | head -n1 || echo unknown)"
  echo "warning: gitleaks ${installed_version} is too old (need 8.16+ for 'git --staged');"
  echo "         skipping pre-commit secret scan. Upgrade with 'brew upgrade gitleaks'."
  exit 0
fi

# `git --staged` scans only the changes about to be committed, using
# the project-level `.gitleaks.toml` config (allowlist for the
# documented finding-signature format).
gitleaks git --staged --redact --no-banner --verbose

# Run clippy on commits that touch Rust files to catch
# cognitive-complexity and other lint regressions before they land.
# Skipped when no `.rs` files are staged (docs/CI/config changes
# would otherwise pay the compile cost for no benefit). The lint
# `cognitive_complexity` is gated at threshold 60 via clippy.toml,
# SonarCloud cloud scan remains the canonical gate at 15. Override
# via `SKIP_CLIPPY=1 git commit ...` if you must bypass.
if [ "${SKIP_CLIPPY:-0}" = "1" ]; then
  echo "SKIP_CLIPPY=1, skipping cargo clippy pre-commit check."
  exit 0
fi
staged_rust_files="$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.rs$' || true)"
if [ -z "${staged_rust_files}" ]; then
  exit 0
fi
if ! command -v cargo > /dev/null 2>&1; then
  echo "warning: cargo not on PATH; skipping pre-commit clippy check."
  exit 0
fi
echo "Running cargo clippy on staged Rust changes..."
cargo clippy --workspace --features daemon -- -D warnings
