{
  "compilerOptions": {
    "target": "ES2024",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2024", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "noEmit": true
  },
  "include": [
    "global-setup.ts",
    "global-teardown.ts",
    "playwright.config.ts",
    "playwright.demo.config.ts",
    "tests/**/*.ts",
    "demo/**/*.ts"
  ]
}
